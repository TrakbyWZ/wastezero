# # Supabase General
# SUPABASE_PUBLIC_URL=http://localhost:8000
# SUPABASE_URL=http://localhost:8000
# SUPABASE_ANON_KEY=use-a-real-jwt-token-generator-to-make-these-keys
# SUPABASE_SERVICE_ROLE_KEY=use-a-real-jwt-token-generator-to-make-these-keys
# JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
# # Service Keys (simulated, usually you generate these)
# # You can use `openssl rand -base64 32` for secrets in prod

# # Auth (GoTrue)
# GOTRUE_JWT_SECRET=${JWT_SECRET}
# GOTRUE_SITE_URL=http://localhost:3000
# GOTRUE_DB_DRIVER=postgres
# GOTRUE_DB_DATABASE_URL=postgres://postgres:${POSTGRES_PASSWORD}@db:5432/postgres?sslmode=disable&search_path=auth
# GOTRUE_API_HOST=0.0.0.0
# GOTRUE_PORT=9999

# # REST (PostgREST)
# PGRST_DB_URI=postgres://postgres:${POSTGRES_PASSWORD}@db:5432/postgres?sslmode=disable
# PGRST_DB_SCHEMA=public,storage,graphql_public
# PGRST_DB_ANON_ROLE=anon
# PGRST_JWT_SECRET=${JWT_SECRET}
# PGRST_SERVER_HOST=*
# PGRST_SERVER_PORT=3000

# # Realtime
# REALTIME_DB_HOST=db
# REALTIME_DB_PORT=5432
# REALTIME_DB_USER=postgres
# REALTIME_DB_PASSWORD=${POSTGRES_PASSWORD}
# REALTIME_DB_NAME=postgres
# REALTIME_DB_SSL=false
# REALTIME_JWT_SECRET=${JWT_SECRET}
# REALTIME_REPLICATION_MODE=RUL
# REALTIME_SLOT_NAME=supabase_realtime_rls

# # Storage
# STORAGE_DB_URL=postgres://postgres:${POSTGRES_PASSWORD}@db:5432/postgres?sslmode=disable
# STORAGE_FILE_SIZE_LIMIT=52428800

# # Studio
# STUDIO_DEFAULT_ORGANIZATION=Default Organization
# STUDIO_DEFAULT_PROJECT=Default Project
# STUDIO_PORT=3000
# # Supabase Studio needs the anon key for some operations, usually passed via UI or env

# # Kong (API Gateway)
# KONG_DATABASE=off
# KONG_DECLARATIVE_CONFIG=/usr/local/kong/declarative/kong.yml
# KONG_DNS_ORDER=LAST,A,CNAME
# KONG_PLUGINS=request-transformer,cors,key-auth,acl
