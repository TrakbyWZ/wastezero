# Supabase (used by Next.js when running locally via npm run dev / pnpm dev)
# Copy to .env.local and set values for your environment.

# --- Remote (hosted) Supabase ---
# From project settings > API: https://app.supabase.com/project/_/settings/api
# NEXT_PUBLIC_SUPABASE_URL=your-project-url
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# --- Local Supabase (recommended for local dev) ---
# 1. Start local Supabase: npx supabase start
# 2. Get URL and keys from the CLI output, or run: npx supabase status -o env
# 3. Use those values in .env.local:
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
OTP_FROM_EMAIL=no-reply@wastezero.com

# --- OTP login (passwordless) ---
# Required: secret for signing session cookies (e.g. openssl rand -base64 32)
SESSION_SECRET=EPNbNUDKkShvODJYbYusk7Xddwdh5g7zErui3l1vUi0=
# Required for OTP APIs: Supabase service role key (from Dashboard > API or: npx supabase status -o env)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InRzdGNxbG11ZWlxdGp5ZGFwdmV1Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc2ODE3MzYwMywiZXhwIjoyMDgzNzQ5NjAzfQ.IdwKxpwq0nTFCwp8zfV59JMMAkGBY9jRy2t8soB-mU4
# Optional: for pnpm create-users --linked (remote/linked Supabase project URL and service role key)
# LINKED_SUPABASE_URL=https://your-project-ref.supabase.co
# LINKED_SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Optional: send OTP by email. Resend is recommended for Vercel (get API key at https://resend.com).
# RESEND_API_KEY=re_xxxx
# OTP_FROM_EMAIL=WasteZero <onboarding@resend.dev>
# Alternative: SMTP (e.g. your own mail server)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASSWORD=your-smtp-password
# OTP_FROM_EMAIL=WasteZero <no-reply@wastezero.com>
# If neither is set, OTP code is logged to the server console (dev only).

# Optional: API key for the Windows file upload service (ingest endpoint).
# If set, POST /api/synced-files/ingest accepts X-API-Key header with this value.
# SYNCED_FILES_INGEST_API_KEY=



