# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/output/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Docker / Supabase local (.docker/volumes for PostgreSQL, etc.)
.docker/
docker/volumes/**/*
supabase/.temp
supabase/.branches

.downloads/**/*

# built docs (legacy)
/docs/build

# Docusaurus: copied into Next for /docs (regenerated on `pnpm build`)
public/docs
# Docusaurus (docs-site)
/docs-site/build
/docs-site/.docusaurus
/docs-site/node_modules

dist