# Optional: override config via environment variables.
# Copy to .env and set values. config.json is still read first; these override.

# WATCH_DIRECTORIES = JSON array of paths, e.g. ["C:\\PrinterLogs","D:\\Logs"]
# API_ENDPOINT = https://your-app.example.com/api/log-files/ingest
# API_KEY = your-ingest-api-key
# POLLING_INTERVAL = 60
# STATE_FILE = sent_files.json
# LOG_DIR = logs
