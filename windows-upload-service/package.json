{
  "name": "wastezero-windows-upload-service",
  "version": "1.0.0",
  "description": "Background service to watch Windows directories for printer log files and upload them to the WasteZero API",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "install-service": "node scripts/install-service.js install",
    "uninstall-service": "node scripts/install-service.js uninstall",
    "test": "node --test",
    "upload": "tsx test/upload-file.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "node-windows": "^1.0.0-beta.8"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
